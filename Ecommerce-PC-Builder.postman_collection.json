{
  "info": {
    "name": "E-Commerce PC Builder API",
    "description": "Postman collection for the Laravel (Porto Architecture) backend API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (Placeholder)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"password\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Catalog",
      "item": [
        {
          "name": "List Products (Placeholder)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "products"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "PC Builder",
      "item": [
        {
          "name": "Get Compatibility (Placeholder)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/pc-builder/compatibility",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "pc-builder",
                "compatibility"
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:8000",
      "type": "string"
    }
  ]
}
